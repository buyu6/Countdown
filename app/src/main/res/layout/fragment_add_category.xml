<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_background"
    android:paddingStart="18dp"
    android:paddingEnd="18dp"
    android:paddingTop="18dp"
    android:paddingBottom="16dp"
>

    <!-- 输入分类名称卡片 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_white_card"
        android:elevation="3dp"
        android:padding="18dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="分类名称"
            android:textColor="#2C2C2C"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="给你的倒数日分类起一个名字"
            android:textColor="#8A8F98"
            android:textSize="13sp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="14dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_input_category"
            android:paddingStart="16dp"
            android:paddingEnd="14dp">

            <ImageView
                android:layout_width="23dp"
                android:layout_height="23dp"
                android:src="@drawable/ic_dashboard"
                app:tint="#4A90E2"
                android:layout_marginEnd="12dp"
                tools:ignore="ContentDescription" />

            <EditText
                android:id="@+id/bookName"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="请输入分类名称"
                android:textColor="#222222"
                android:textColorHint="#A6B0BE"
                android:textSize="15sp"
                android:singleLine="true"
                android:padding="0dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- 图标选择卡片 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@drawable/bg_white_card"
        android:elevation="3dp"
        android:padding="16dp">

        <!-- 图标选择标题 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_add_category"
            android:paddingStart="16dp"
            android:paddingEnd="14dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/miss"
                app:tint="#4A90E2"
                android:layout_marginEnd="12dp"
                tools:ignore="ContentDescription" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="选择图标"
                android:textSize="17sp"
                android:textColor="#2C2C2C"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:gravity="center"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="请选择"
                android:textSize="13sp"
                android:textColor="#4A90E2"
                android:background="@drawable/bg_add_button" />

        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/iconRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingTop="16dp"
            android:paddingBottom="10dp"
            android:overScrollMode="never" />

    </LinearLayout>

    <!-- 保存按钮 -->
    <Button
        android:id="@+id/savebutton"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:text="保存"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:textSize="16sp"
        android:background="@drawable/bg_save_button"
        android:layout_marginTop="16dp"
        android:elevation="3dp"
        app:backgroundTint="#4A90E2" />

</LinearLayout>