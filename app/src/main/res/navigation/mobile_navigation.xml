<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mobile_navigation"
    app:startDestination="@id/launchFragemnt">

    <fragment
        android:id="@+id/navigation_home"
        android:name="com.example.daysmatter.ui.home.HomeFragment"
        android:label="@string/title_home"
        tools:layout="@layout/fragment_home" />

    <fragment
        android:id="@+id/navigation_dashboard"
        android:name="com.example.daysmatter.ui.dashboard.DashboardFragment"
        android:label="@string/title_dashboard"
        tools:layout="@layout/fragment_dashboard" />

    <fragment
        android:id="@+id/navigation_notifications"
        android:name="com.example.daysmatter.ui.notifications.NotificationsFragment"
        android:label="@string/title_notifications"
        tools:layout="@layout/fragment_notifications" />
    <fragment
        android:id="@+id/launchFragemnt"
        android:name="com.example.daysmatter.ui.launch.LaunchFragemnt"
        android:label="fragment_launch_fragemnt"
        tools:layout="@layout/fragment_launch_fragemnt" >
        <action
            android:id="@+id/action_launchFragemnt_to_navigation_home"
            app:destination="@id/navigation_home" />
        <action
            android:id="@+id/action_launchFragemnt_to_navigation_home2"
            app:destination="@id/navigation_home" />
    </fragment>
</navigation>